<style>
    footer {
        background: #222;
        border-top: 1px solid var(--border);
        padding: 48px;
    }
    .footer {
        margin-left: var(--sidebar-w);
        transition: margin-left var(--transition);
    }
    .footer.footer-collapsed {
        margin-left: var(--sidebar-w-col);
    }
    .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 40px;
        align-items: start;
    }
    .sidebar-logo {
        width: 40px;
        height: 40px;
        min-width: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--accent), #1a8c82);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'JetBrains Mono', monospace;
        font-weight: 600;
        font-size: 16px;
        color: #1a1a1a;
    }
    .footer-links {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
        margin-top: 16px;
    }
    .footer-links a {
        color: var(--muted);
        font-size: 14px;
        text-decoration: none;
        transition: color var(--transition);
    }
    .footer-links a:hover {
        color: var(--accent);
    }
    .footer-copy {
        color: var(--muted2);
        font-size: 13px;
        margin-top: 24px;
        font-family: 'JetBrains Mono', monospace;
    }
    .footer-socials {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        justify-content: space-evenly;
    }
    @media (max-width: 1024px) {
        .footer-inner {
            grid-template-columns: 1fr; 
        }
    }
    @media (max-width: 768px) {
        .footer {
            margin-left: var(--sidebar-w-col);
        }
        .footer.expanded {
            margin-left: var(--sidebar-w-col);
        }
    }
</style>

<script>
    window.addEventListener('collapsed-changed', (event) => {
        console.log('Colapso cambiado:', (event as CustomEvent).detail.collapse);
        const collapsed = (event as CustomEvent).detail.collapse;
        const footer = document.querySelectorAll(".footer")[0] as HTMLElement;
        footer.classList.toggle("footer-collapsed", collapsed);
    });
</script>
