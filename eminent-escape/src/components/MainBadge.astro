---
const {class: className, text} = Astro.props;
---
<div class={`hero-badge ${className}`}>
    <span class="hero-badge-dot"></span>
    {text}
</div>

<style>
    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--accent-dim);
        border: 1px solid rgba(64,224,208,0.3);
        color: var(--accent);
        padding: 6px 16px;
        border-radius: 100px;
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 24px;
        width: fit-content;   
    }
    .hero-badge-dot {
        width: 8px; height: 8px;
        background: var(--accent);
        border-radius: 50%;
        animation: pulse 2s infinite;
    }
    @keyframes pulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }
        50% {
            opacity: 0.5;
            transform: scale(0.8);
        }    
    }
</style>