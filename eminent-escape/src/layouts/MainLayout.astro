---
import '../styles/global.css';
import SideBar from '../components/SideBar.astro';
import Footer from '../components/Footer.astro';

const {title, description} = Astro.props as { title: string, description: string };

const navItems = [
  {customHref: "/", icon: "home", navText: "Inicio"},
  {customHref: "/sobre-mi", icon: "person", navText: "Sobre mí"},
  {customHref: "/blog", icon: "article", navText: "Blog"},
  {customHref: "/portafolio", icon: "work", navText: "Portafolio"},
  {customHref: "/contacto", icon: "mail", navText: "Contacto"},
];

const links = [
  {href: "/", text: "Inicio"},
  {href: "/sobre-mi", text: "Sobre mí"},
  {href: "/blog", text: "Blog"},
  {href: "/portafolio", text: "Portafolio"},
  {href: "/contacto", text: "Contacto"},
  {href: "/politica-de-privacidad", text: "Política de privacidad"}
];
---
<!doctype html>
<html lang="es-Mx">
	<head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon" />
        <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
        <meta name="generator" content={Astro.generator} />
        <meta name="author" content="Luis Gerardo Márquez Méndez" />
        <title>{title}</title>
        <meta name="description" content={description} />
    </head>
    <body class="bg-primary text-secondary">
        <SideBar navItems={navItems}/>
        <main class="main">
            <slot/>
        </main>
        <Footer links={links} />
    </body>
</html>

<style>
    .main {
        margin-left: var(--sidebar-w);
        padding: 24px;
        transition: margin-left var(--transition);
    }
    .main.main-collapsed {
        margin-left: var(--sidebar-w-col);
    }
    .main.expanded {
        margin-left: var(--sidebar-w-col);
    }
    @media (max-width: 768px) {
        .main {
            margin-left: var(--sidebar-w-col);
        }
        .main.expanded {
            margin-left: var(--sidebar-w-col);
        }
    }
</style>